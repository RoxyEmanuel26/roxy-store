# ==========================================
# Roxy Store E-Commerce — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git!

# ── Database (WAJIB) ──────────────────────
DATABASE_URL="postgresql://postgres:password@host:port/railway"

# ── Auth (WAJIB) ──────────────────────────
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── Cloudinary (WAJIB untuk upload foto) ──
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── WhatsApp (OPSIONAL) ──────────────────
NEXT_PUBLIC_WA_NUMBER="628xxxxxxxxxx"

# ── Google Analytics 4 (OPSIONAL) ────────
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── Microsoft Clarity (OPSIONAL) ─────────
NEXT_PUBLIC_CLARITY_ID="xxxxxxxxxx"

# ── Facebook Pixel + Conversions API (OPSIONAL) ──
# Client-side Pixel ID (visible di browser)
NEXT_PUBLIC_FB_PIXEL_ID="123456789012345"
# Server-side: Pixel ID + Access Token (hanya di server, JANGAN pakai NEXT_PUBLIC_)
FB_PIXEL_ID="123456789012345"
FB_ACCESS_TOKEN="EAAxxxxxxx..."
# Dapatkan Access Token di:
# Meta Events Manager → Settings → Conversions API → Generate Access Token

# ── Sentry Error Monitoring (OPSIONAL) ───
NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_AUTH_TOKEN="your-sentry-auth-token-for-sourcemaps"

# ── Upstash Redis (OPSIONAL, rate limit) ─
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================
# INITIAL ADMIN AUTH (Digunakan saat npx prisma db seed)
# ============================================
ADMIN_INITIAL_EMAIL=""
ADMIN_INITIAL_PASSWORD=""